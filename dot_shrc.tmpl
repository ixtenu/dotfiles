# Generic shell initialization
# Can be sourced from .zshrc, .bashrc, .kshrc, etc.

iscmd() {
  command -v "$1" >/dev/null 2>&1
}

alias df='df -h'
alias du='du -h'
{{- if ne .chezmoi.os "openbsd" }}
alias grep='grep --color=auto'
{{- end }}
# ls
{{- if eq .chezmoi.os "openbsd" }}
alias ls='ls -hF'
{{- else }}
alias ls='ls -hF --color=auto'
{{- end }}
alias lr='ls -R' # recursive ls
alias ll='ls -l' # detailed ls
alias la='ll -A' # detailed ls, including dotfiles
{{- if eq .chezmoi.os "linux" }}
alias lx='ll -BX' # sort by extension
{{- end }}
alias lz='ll -rS' # sort by size
alias lt='ll -rt' # sort by date
{{- if eq .chezmoi.os "linux" }}
alias chown='chown --preserve-root'
alias chmod='chmod --preserve-root'
alias chgrp='chgrp --preserve-root'
{{- end }}

# Add directory to PATH if it exists and isn't already in PATH.
addtopath() {
  [ ! -d $1 ] && return
  echo "$PATH" | grep ":$1$" >/dev/null && return
  echo "$PATH" | grep ":$1:" >/dev/null && return
  export PATH=$PATH:$1
}

addtopath $HOME/bin
addtopath $HOME/.local/bin
addtopath $HOME/go/bin
addtopath $HOME/.cargo/bin

if [ -d /usr/local/plan9 ]; then
  export PLAN9=/usr/local/plan9
elif [ -d $HOME/plan9 ]; then
  export PLAN9=$HOME/plan9
fi
[ ! -z "$PLAN9" ] && addtopath $PLAN9/bin

# The vis text editor installs as vise in *BSD userlands because there's a
# vis(1) utility in the base system.
{{- if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "freebsd") (eq .chezmoi.os "openbsd") }}
if iscmd vise; then
  alias visu='/usr/bin/vis'
  alias vis='vise'
fi
{{- end }}

export EDITOR='dte'
export VISUAL='dte'

# Short-hand for the default editor
[ -n "$VISUAL" ] && alias e="$VISUAL"

if iscmd fzf; then
  fzp() {
    if [ $# -lt 1 ]; then
      echo "fzp: must specify a program name" 1>&2
      return 1
    fi
    program="$1"
    shift
    "$program" "$@" $(fzf -m)
  }

  fze() {
    if [ -z "$VISUAL" ]; then
      echo "fze: cannot open editor when VISUAL is unset"
      return 1
    fi
    fzp "$VISUAL" "$@"
  }
fi

mkcd() {
  if [ $# -eq 0 ]; then
    echo "$0: missing operand" 1>&2
    echo "usage: $0 directory" 1>&2
    echo "mkdir and chdir into the given directory." 1>&2
    return 1
  fi
  mkdir -p "$1"
  cd "$1"
}

upcd() {
  dir=""
  for i in $(seq 1 $1); do
    dir="../$dir"
  done
  [ -z "$dir" ] && dir="$PWD"
  cd "$dir"
}

lk() {
  if ! iscmd walk; then
    echo "lk: walk must be installed" 1>&2
    return 1
  fi
  cd "$(walk "$@")"
}

# Debian/Ubuntu renamed fd to fdfind due to a naming conflict.
iscmd fdfind && ! iscmd fd && alias fd='fdfind'

# GNU Emacs
if iscmd emacs; then
  alias ge='emacs -nw'
  alias gec='emacsclient -n'
fi

# Consistent name for Sublime Merge
if ! iscmd subm; then
  if iscmd sublime_merge; then
    alias subm='sublime_merge'
  elif iscmd subl-merge; then
    alias subm='subl-merge'
  elif iscmd smerge; then
    alias subm='smerge'
  elif iscmd flatpak; then
    if flatpak info com.sublimemerge.App >/dev/null 2>&1; then
      alias subm='flatpak run com.sublimemerge.App'
    fi
  fi
fi
# Consistent name for Sublime Text
if ! iscmd subl; then
  if iscmd sublime_text; then
    alias subl='sublime_text'
  elif iscmd subl-text; then
    alias subl='subl-text'
  elif iscmd subl4; then
    alias subl='subl4'
  elif iscmd flatpak; then
    if flatpak info com.sublimehq.SublimeText >/dev/null 2>&1; then
      alias subl='flatpak run com.sublimehq.SublimeText'
    fi
  fi
fi

# Joe's Own Editor
if iscmd joe; then
  alias joe='ec-wrapper joe'
  alias jmacs='ec-wrapper jmacs'
  alias jpico='ec-wrapper jpico'
  alias jstar='ec-wrapper jstar'
  alias jo='joe'
  alias jm='jmacs'
  alias jp='jpico'
  alias js='jstar'
fi

# GNU nano
if iscmd nano; then
  alias nano='ec-wrapper nano'
  alias na='nano'
fi

# godit
if iscmd godit; then
  alias godit='ec-wrapper godit'
  alias gd='godit'
fi

# work around https://github.com/martanne/vis/issues/1252
if [ "$TERM" = "foot" ]; then
  alias vis='TERM=xterm-256color vis'
fi

# Machine-local customizations (must be last)
[ -f "$HOME/.shrc-local" ] && source "$HOME/.shrc-local"
